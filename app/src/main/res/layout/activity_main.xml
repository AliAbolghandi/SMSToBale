<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:background="@color/bg_dark"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SMS To Bale"
        android:textSize="19sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="کنترل فوروارد پیامک‌های بانکی به بله"
        android:textSize="12sp"
        android:textColor="@color/text_secondary" />

    <!-- Permission status chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp">

        <LinearLayout
            android:id="@+id/permReceiveSms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_input_field"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/permReceiveSmsIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="@color/status_error"
                android:textStyle="bold"
                android:layout_marginStart="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="دریافت پیامک"
                android:textSize="11sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/permReadSms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_input_field"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/permReadSmsIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="@color/status_error"
                android:textStyle="bold"
                android:layout_marginStart="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="خواندن پیامک"
                android:textSize="11sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

    </LinearLayout>

    <!-- Tab bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_field"
        android:padding="5dp"
        android:layout_marginTop="14dp">

        <TextView
            android:id="@+id/tabSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="10dp"
            android:text="تنظیمات"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_tab_active" />

        <TextView
            android:id="@+id/tabHistory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="10dp"
            android:text="تاریخچه"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

    <!-- Content area (swipeable) -->
    <com.example.smstobale.SwipeableFrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp">

        <!-- Settings panel -->
        <ScrollView
            android:id="@+id/scrollSettings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="20dp">

                <!-- Auto-forward toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="فوروارد خودکار"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="دریافت و ارسال پیامک‌های منطبق"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/switchAutoForward"
                        android:layout_width="46dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_switch_on">
                        <View
                            android:id="@+id/switchThumb"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="end"
                            android:layout_marginHorizontal="3dp"
                            android:background="@drawable/bg_switch_thumb" />
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="منبع(های) پیامک (شماره یا نام بانک)"
                    android:textColor="@color/accent_turquoise"
                    android:textSize="13sp" />
                <EditText
                    android:id="@+id/etSourceNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_input_field"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:inputType="text"
                    android:hint="مثال: 3000175, بانک ملت, +989121234567" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:text="هم شماره معمولی و هم Sender ID متنی بانک را می‌پذیرد. برای چند منبع، آن‌ها را با کاما (,) جدا کنید." />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="آدرس Web App اسکریپت گوگل"
                    android:textColor="@color/accent_turquoise"
                    android:textSize="13sp" />
                <EditText
                    android:id="@+id/etWebAppUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_input_field"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:inputType="textUri"
                    android:hint="https://script.google.com/macros/s/.../exec" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Chat ID مخاطب(ها) در بله"
                    android:textColor="@color/accent_turquoise"
                    android:textSize="13sp" />
                <EditText
                    android:id="@+id/etChatId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_input_field"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:inputType="text"
                    android:hint="مثال: 123456789, 987654321" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:text="برای ارسال به چند مخاطب، Chat ID ها را با کاما (,) جدا کنید." />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="کلید محرمانه (Secret Key)"
                    android:textColor="@color/accent_turquoise"
                    android:textSize="13sp" />
                <EditText
                    android:id="@+id/etSecretKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_input_field"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:inputType="textPassword"
                    android:hint="یک متن دلخواه امن - باید دقیقا مثل اسکریپت باشد" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="26dp"
                    android:background="@drawable/ripple_button_primary"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:elevation="0dp"
                    android:text="ذخیره تنظیمات" />

            </LinearLayout>
        </ScrollView>

        <!-- History panel -->
        <LinearLayout
            android:id="@+id/panelHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/btnClearLogs"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/ripple_button_danger"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:elevation="0dp"
                android:text="پاک کردن تاریخچه" />

            <ListView
                android:id="@+id/listViewLogs"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="12dp"
                android:scrollbars="none"
                android:divider="@android:color/transparent"
                android:dividerHeight="10dp" />

        </LinearLayout>

    </com.example.smstobale.SwipeableFrameLayout>

</LinearLayout>
